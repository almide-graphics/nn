// nn.qwen_tokenizer — byte-level BPE (GPT-2 family) for Qwen3, loaded from
// GGUF metadata (tokenizer.ggml.tokens / tokenizer.ggml.merges).
//
// Pure Almide on purpose: the tokenizer must run on BOTH targets (native
// engine and the browser WASM port) — native Rust modules exist only on
// the Rust target. Dictionary lookups use sorted parallel lists + binary
// search (the stdlib map is insertion-ordered linear — unusable at 152k
// entries).
//
// The pretokenizer hand-codes Qwen2/3's split regex, alternation order
// preserved:
//   (?i:'s|'t|'re|'ve|'m|'ll|'d) | [^\r\n\p{L}\p{N}]?\p{L}+ | \p{N}{1,3}
//   |  ?[^\s\p{L}\p{N}]+[\r\n]* | \s*[\r\n]+ | \s+(?!\S) | \s+
// Validated against the HF tokenization of the 20 parity prompts
// (examples/_tokenizer_parity.almd).

import fs
import self.gguf_prims

// Dictionaries are stored as a packed byte blob + Int offset table, NOT
// List[String]: building a 152k-element List[String] is O(n²) on the wasm
// target (heap-element list grow deep-clones per push — almide#695), which
// made the browser load take >5 min. A Bytes blob + List[Int] offsets
// builds in O(n) (List[Int] push is O(1)), is more cache-local at runtime,
// and sorts via direct byte-range comparison — no String materialization.
//
// `String <` in Almide is Rust's bytewise UTF-8 ordering, so comparing the
// raw token bytes reproduces the exact order the old String sort produced.
// Merge rank = original GGUF index (merges are stored highest-priority
// first), so a sorted index doubles as the rank.

type QwenTokenizer = {
  vocab_blob: Bytes,             // token i bytes = blob[off[i] .. off[i+1]]
  vocab_off: List[Int],          // n_vocab + 1 offsets (id order)
  sorted_token_idx: List[Int],   // token ids, sorted by byte content
  merge_blob: Bytes,             // merge i "left right" key bytes
  merge_off: List[Int],          // n_merge + 1 offsets (rank order)
  sorted_merge_idx: List[Int],   // merge indices, sorted by byte content
  byte_to_char: List[String],    // 256 entries
  char_to_byte: List[Int],       // indexed by codepoint (< 0x200), -1 = none
  eos_id: Int,
}

// ── GPT-2 byte ↔ unicode alphabet ──
//
// Printable latin-1 bytes map to themselves; the rest get 0x100+counter.

fn printable_byte(b: Int) -> Bool =
  (b >= 33 and b <= 126) or (b >= 161 and b <= 172) or (b >= 174 and b <= 255)

fn build_byte_maps() -> (List[String], List[Int]) = {
  var b2c: List[String] = []
  var c2b = list.repeat(-1, 512)
  var extra = 0
  var b = 0
  while b < 256 {
    let cp = if printable_byte(b) then b else {
      let v = 256 + extra
      extra = extra + 1
      v
    }
    list.push(b2c, string.from_codepoint(cp))
    c2b = list.set(c2b, cp, b)
    b = b + 1
  }
  (b2c, c2b)
}

// ── packed-blob dictionary ──
//
// Compare a target byte list against blob[b0 .. b1) lexicographically.
// Returns -1 / 0 / 1 (target <, ==, > the blob range). Byte order matches
// Almide String Ord (bytewise UTF-8), so this reproduces the String sort.
fn cmp_target_range(target: List[Int], blob: Bytes, b0: Int, b1: Int) -> Int = {
  var i = 0
  var j = b0
  var r = 0
  let la = list.len(target)
  while r == 0 and i < la and j < b1 {
    let x = list.get(target, i) ?? 0
    let y = bytes.get(blob, j) ?? 0
    if x < y then { r = -1 } else if x > y then { r = 1 }
    i = i + 1
    j = j + 1
  }
  if r != 0 then r
  else {
    let lb = b1 - b0
    if la < lb then -1 else if la > lb then 1 else 0
  }
}

// Compare two blob ranges (used by the load-time sort). Same blob.
fn cmp_ranges(blob: Bytes, a0: Int, a1: Int, b0: Int, b1: Int) -> Int = {
  var i = a0
  var j = b0
  var r = 0
  while r == 0 and i < a1 and j < b1 {
    let x = bytes.get(blob, i) ?? 0
    let y = bytes.get(blob, j) ?? 0
    if x < y then { r = -1 } else if x > y then { r = 1 }
    i = i + 1
    j = j + 1
  }
  if r != 0 then r
  else {
    let la = a1 - a0
    let lb = b1 - b0
    if la < lb then -1 else if la > lb then 1 else 0
  }
}

// Bottom-up merge sort of `idx` (entry indices) by the byte content of
// blob[off[e] .. off[e+1]]. Flat function, no closures (a closure capturing
// `blob` would clone the whole buffer), List[Int] intermediates only → O(n
// log n) with O(1) pushes, zero String allocation.
fn sort_by_blob(idx: List[Int], blob: Bytes, off: List[Int]) -> List[Int] = {
  let n = list.len(idx)
  // owned copy: binding a borrowed-slice param straight to `var` mis-lowers
  // to a reference clone (Vec vs &[i64])
  var cur = list.slice(idx, 0, n)
  var width = 1
  while width < n {
    var merged: List[Int] = []
    var lo = 0
    while lo < n {
      let mid = if lo + width < n then lo + width else n
      let hi = if lo + 2 * width < n then lo + 2 * width else n
      var i = lo
      var j = mid
      while i < mid and j < hi {
        let ea = list.get(cur, i) ?? 0
        let eb = list.get(cur, j) ?? 0
        let c = cmp_ranges(blob,
          list.get(off, ea) ?? 0, list.get(off, ea + 1) ?? 0,
          list.get(off, eb) ?? 0, list.get(off, eb + 1) ?? 0)
        if c <= 0 then { list.push(merged, ea); i = i + 1 }
        else { list.push(merged, eb); j = j + 1 }
      }
      while i < mid { list.push(merged, list.get(cur, i) ?? 0); i = i + 1 }
      while j < hi { list.push(merged, list.get(cur, j) ?? 0); j = j + 1 }
      lo = lo + 2 * width
    }
    cur = merged
    width = width * 2
  }
  cur
}

// ── Pretokenizer ──
//
// char_at returns "" out of range; the predicates treat "" as no-match
// (string.is_* are all-chars predicates, so they return true on "").

fn char_at(cs: List[String], i: Int) -> String =
  list.get(cs, i) ?? ""

fn is_letter(c: String) -> Bool =
  c != "" and string.is_alpha(c)

fn is_number(c: String) -> Bool =
  c != "" and string.is_digit(c)

fn is_space_char(c: String) -> Bool =
  c != "" and string.is_whitespace(c)

fn is_newline(c: String) -> Bool =
  c == "\n" or c == "\r"

fn is_punct(c: String) -> Bool =
  c != "" and not is_space_char(c) and not is_letter(c) and not is_number(c)

fn join_range(cs: List[String], a: Int, b: Int) -> String =
  list.slice(cs, a, b) |> list.join("")

// English contraction group at an apostrophe; returns matched length
// (including the apostrophe) or 0.
fn contraction_len(cs: List[String], i: Int) -> Int = {
  let c1 = string.to_lower(char_at(cs, i + 1))
  let c2 = string.to_lower(char_at(cs, i + 2))
  if (c1 == "r" and c2 == "e") or (c1 == "v" and c2 == "e") or (c1 == "l" and c2 == "l") then 3
  else if c1 == "s" or c1 == "t" or c1 == "m" or c1 == "d" then 2
  else 0
}

fn pretokenize(text: String) -> List[String] = {
  let cs = string.chars(text)
  let n = list.len(cs)
  var out: List[String] = []
  var i = 0
  while i < n {
    let c = char_at(cs, i)
    let nx = char_at(cs, i + 1)
    // 1. contraction: (?i:'s|'t|'re|'ve|'m|'ll|'d)
    if c == "'" and contraction_len(cs, i) > 0 then {
      let l = contraction_len(cs, i)
      list.push(out, join_range(cs, i, i + l))
      i = i + l
    }
    // 2. [^\r\n\p{L}\p{N}]?\p{L}+ — the optional prefix may be ANY
    //    non-letter/number/newline char, including a space.
    else if is_letter(c) or
            (not is_letter(c) and not is_number(c) and not is_newline(c) and is_letter(nx)) then {
      var k = if is_letter(c) then i else i + 1
      while k < n and is_letter(char_at(cs, k)) {
        k = k + 1
      }
      list.push(out, join_range(cs, i, k))
      i = k
    }
    // 3. \p{N}{1,3}
    else if is_number(c) then {
      var k = i
      while k < n and k < i + 3 and is_number(char_at(cs, k)) {
        k = k + 1
      }
      list.push(out, join_range(cs, i, k))
      i = k
    }
    // 4.  ?[^\s\p{L}\p{N}]+[\r\n]*
    else if is_punct(c) or (c == " " and is_punct(nx)) then {
      var k = if is_punct(c) then i else i + 1
      while k < n and is_punct(char_at(cs, k)) {
        k = k + 1
      }
      while k < n and is_newline(char_at(cs, k)) {
        k = k + 1
      }
      list.push(out, join_range(cs, i, k))
      i = k
    }
    // 5/6/7. whitespace families
    else {
      var e = i
      var last_nl = -1
      while e < n and is_space_char(char_at(cs, e)) {
        if is_newline(char_at(cs, e)) then {
          last_nl = e
        }
        e = e + 1
      }
      if e == i then {
        // defensive: unclassifiable char — emit alone, never stall
        list.push(out, c)
        i = i + 1
      } else if last_nl >= 0 then {
        // \s*[\r\n]+ — up to and including the last newline of the run
        list.push(out, join_range(cs, i, last_nl + 1))
        i = last_nl + 1
      } else if e >= n then {
        // \s+(?!\S) — trailing whitespace keeps everything
        list.push(out, join_range(cs, i, e))
        i = e
      } else if e - i > 1 then {
        // \s+(?!\S) backtracks: leave the last space for the next token
        list.push(out, join_range(cs, i, e - 1))
        i = e - 1
      } else {
        // single whitespace before a non-space the later groups reject
        // (e.g. a digit): plain \s+
        list.push(out, c)
        i = i + 1
      }
    }
  }
  out
}

// ── BPE ──
//
// One flat function on purpose: a user-fn boundary or closure capture
// passes values BY VALUE, so routing the dictionaries through vocab_id/
// merge_rank-style helpers clones all ~600k strings per lookup (measured:
// 71s for 20 prompts). Intrinsics like list.get borrow, so keeping every
// lookup inline against t's fields makes encode allocation-free apart
// from the pieces themselves.

// Exact-match id of a whole token string (e.g. a special token like
// "<|im_start|>" that never goes through BPE). -1 if absent. Clones the
// record by value — startup/setup use only, not a hot path.
fn token_to_id(t: QwenTokenizer, s: String) -> Int = {
  let target = string.to_bytes(s)
  var lo = 0
  var hi = list.len(t.sorted_token_idx) - 1
  var id = -1
  while lo <= hi {
    let mid = (lo + hi) / 2
    let tid = list.get(t.sorted_token_idx, mid) ?? 0
    let c = cmp_target_range(target, t.vocab_blob,
      list.get(t.vocab_off, tid) ?? 0, list.get(t.vocab_off, tid + 1) ?? 0)
    if c == 0 then { id = tid; lo = hi + 1 }
    else if c > 0 then { lo = mid + 1 }
    else { hi = mid - 1 }
  }
  id
}

fn encode(t: QwenTokenizer, text: String) -> List[Int] = {
  var out: List[Int] = []
  for pre in pretokenize(text) {
    // bytes → mapped alphabet chars
    var pieces: List[String] = []
    for b in string.to_bytes(pre) {
      list.push(pieces, list.get(t.byte_to_char, b) ?? "")
    }
    // merge loop: lowest-rank adjacent pair, all its occurrences, repeat.
    // Merge rank = the sorted entry's original index (merges stored
    // highest-priority first), so a hit at sorted position mid has rank
    // sorted_merge_idx[mid]; pick the smallest such across all pairs.
    var go = list.len(pieces) > 1
    while go {
      var best_rank = 2147483647
      var best_i = -1
      var i = 0
      while i < list.len(pieces) - 1 {
        // target bytes = bytes(a) ++ ' ' ++ bytes(b)
        let target = string.to_bytes(list.get(pieces, i) ?? "")
          + [32] + string.to_bytes(list.get(pieces, i + 1) ?? "")
        var lo = 0
        var hi = list.len(t.sorted_merge_idx) - 1
        while lo <= hi {
          let mid = (lo + hi) / 2
          let idx = list.get(t.sorted_merge_idx, mid) ?? 0
          let c = cmp_target_range(target, t.merge_blob,
            list.get(t.merge_off, idx) ?? 0, list.get(t.merge_off, idx + 1) ?? 0)
          if c == 0 then {
            if idx < best_rank then {
              best_rank = idx
              best_i = i
            }
            lo = hi + 1
          } else if c > 0 then {
            lo = mid + 1
          } else {
            hi = mid - 1
          }
        }
        i = i + 1
      }
      if best_i < 0 then {
        go = false
      } else {
        let a = list.get(pieces, best_i) ?? ""
        let b = list.get(pieces, best_i + 1) ?? ""
        let merged = a + b
        var np: List[String] = []
        var j = 0
        while j < list.len(pieces) {
          if j < list.len(pieces) - 1
             and (list.get(pieces, j) ?? "") == a
             and (list.get(pieces, j + 1) ?? "") == b then {
            list.push(np, merged)
            j = j + 2
          } else {
            list.push(np, list.get(pieces, j) ?? "")
            j = j + 1
          }
        }
        pieces = np
        go = list.len(pieces) > 1
      }
    }
    // vocab lookup: compare piece bytes against the sorted blob ranges
    for p in pieces {
      let target = string.to_bytes(p)
      var lo = 0
      var hi = list.len(t.sorted_token_idx) - 1
      var id = -1
      while lo <= hi {
        let mid = (lo + hi) / 2
        let tid = list.get(t.sorted_token_idx, mid) ?? 0
        let c = cmp_target_range(target, t.vocab_blob,
          list.get(t.vocab_off, tid) ?? 0, list.get(t.vocab_off, tid + 1) ?? 0)
        if c == 0 then {
          id = tid
          lo = hi + 1
        } else if c > 0 then {
          lo = mid + 1
        } else {
          hi = mid - 1
        }
      }
      if id >= 0 then {
        list.push(out, id)
      }
    }
  }
  out
}

// Decoded UTF-8 bytes of a single token id (inverse byte map applied).
// For streaming: append to a buffer and flush at UTF-8 boundaries.
// Control/special tokens (e.g. <|im_end|>) decode to no bytes.
fn token_bytes(t: QwenTokenizer, id: Int) -> List[Int] = {
  let s = list.get(t.vocab_off, id) ?? 0
  let e = list.get(t.vocab_off, id + 1) ?? 0
  var tb: List[Int] = []
  var bi = s
  while bi < e {
    list.push(tb, bytes.get(t.vocab_blob, bi) ?? 0)
    bi = bi + 1
  }
  var out: List[Int] = []
  for c in string.chars(string.from_bytes(tb)) {
    let cp = string.codepoint(c) ?? 0
    let b = if cp < 512 then list.get(t.char_to_byte, cp) ?? -1 else -1
    if b >= 0 then {
      list.push(out, b)
    }
  }
  out
}

fn decode(t: QwenTokenizer, ids: List[Int]) -> String = {
  var bytes_out: List[Int] = []
  for id in ids {
    for b in token_bytes(t, id) {
      list.push(bytes_out, b)
    }
  }
  string.from_bytes(bytes_out)
}

// ── GGUF loading ──
//
// Read a GGUF string array (elem_type u32 = 8, count u64, then
// length-prefixed strings) into a packed byte blob + an offset table.
// Returns (blob, off): entry i bytes = blob[off[i] .. off[i+1]], with
// off having count+1 entries. Pushes raw bytes into a List[Int] (O(1)
// push) then converts once — never builds a List[String] (almide#695).
fn read_blob(data: Bytes, pos: Int) -> (Bytes, List[Int]) = {
  let count = gguf_prims.r_u64(data, pos + 4)
  var blob: List[Int] = []
  var off: List[Int] = [0]
  var p = pos + 12
  var run = 0
  var i = 0
  while i < count {
    let len = gguf_prims.r_u64(data, p)
    var k = 0
    while k < len {
      list.push(blob, bytes.get(data, p + 8 + k) ?? 0)
      k = k + 1
    }
    run = run + len
    list.push(off, run)
    p = p + 8 + len
    i = i + 1
  }
  (bytes.from_list(blob), off)
}

// Read a GGUF scalar array of ints (u32/i32/u64/i64) into a List[Int].
// O(n) push, no String/sort — used for the precomputed sort permutations.
fn read_int_array(data: Bytes, pos: Int) -> List[Int] = {
  let elem_type = gguf_prims.r_u32(data, pos)
  let count = gguf_prims.r_u64(data, pos + 4)
  let esz = gguf_prims.scalar_size(elem_type)
  var out: List[Int] = []
  var p = pos + 12
  var i = 0
  while i < count {
    list.push(out, gguf_prims.value_as_int(data, p, elem_type))
    p = p + esz
    i = i + 1
  }
  out
}

// Build a tokenizer from GGUF bytes already in memory. Pure (no fs) so it
// runs on the wasm target — the browser fetches the GGUF and hands the
// bytes straight in. The native `load(path)` is a thin file-reading
// wrapper around this.
fn load_from_bytes(data: Bytes) -> Result[QwenTokenizer, String] =
  if gguf_prims.r_u32(data, 0) != 1179993927 then err("not a GGUF file")
  else {
    let metadata_count = gguf_prims.r_u64(data, 16)
    var vocab_blob = bytes.from_list([])
    var vocab_off: List[Int] = []
    var merge_blob = bytes.from_list([])
    var merge_off: List[Int] = []
    // precomputed sort permutations (tools/export_gguf.py); empty = absent
    var tok_sort: List[Int] = []
    var merge_sort: List[Int] = []
    var eos = 151645
    var p = 24
    var i = 0
    while i < metadata_count {
      let (key, p1) = gguf_prims.r_string(data, p)
      let vtype = gguf_prims.r_u32(data, p1)
      let vpos = p1 + 4
      if key == "tokenizer.ggml.tokens" and vtype == 9 then {
        let (b, o) = read_blob(data, vpos)
        vocab_blob = b
        vocab_off = o
      }
      if key == "tokenizer.ggml.merges" and vtype == 9 then {
        let (b, o) = read_blob(data, vpos)
        merge_blob = b
        merge_off = o
      }
      if key == "tokenizer.ggml.token_sort" and vtype == 9 then {
        tok_sort = read_int_array(data, vpos)
      }
      if key == "tokenizer.ggml.merge_sort" and vtype == 9 then {
        merge_sort = read_int_array(data, vpos)
      }
      if key == "tokenizer.ggml.eos_token_id" then {
        eos = gguf_prims.value_as_int(data, vpos, vtype)
      }
      p = gguf_prims.skip_value(data, vpos, vtype)
      i = i + 1
    }
    let n_vocab = list.len(vocab_off) - 1
    if n_vocab <= 0 then err("no tokenizer.ggml.tokens")
    else {
      let (b2c, c2b) = build_byte_maps()
      let n_merge = list.len(merge_off) - 1
      // Use the shipped permutation when present (O(n) read, works on wasm);
      // otherwise sort in-engine (native only — the merge sort traps on the
      // wasm backend at this scale, almide#696).
      let st = if list.len(tok_sort) == n_vocab then tok_sort
               else sort_by_blob(list.range(0, n_vocab), vocab_blob, vocab_off)
      let sm = if list.len(merge_sort) == n_merge then merge_sort
               else sort_by_blob(list.range(0, n_merge), merge_blob, merge_off)
      ok({
        vocab_blob: vocab_blob,
        vocab_off: vocab_off,
        sorted_token_idx: st,
        merge_blob: merge_blob,
        merge_off: merge_off,
        sorted_merge_idx: sm,
        byte_to_char: b2c,
        char_to_byte: c2b,
        eos_id: eos,
      })
    }
  }

effect fn load(path: String) -> Result[QwenTokenizer, String] =
  match fs.read_bytes_raw(path) {
    err(e) => err("failed to read " + path + ": " + e)
    ok(data) => load_from_bytes(data),
  }

// ── Tests (dictionary mechanics — full parity runs in examples/) ──

test "byte maps round-trip every byte" {
  let (b2c, c2b) = build_byte_maps()
  assert_eq(list.len(b2c), 256)
  var good = 0
  var b = 0
  while b < 256 {
    let c = list.get(b2c, b) ?? ""
    let cp = string.codepoint(c) ?? -1
    if (list.get(c2b, cp) ?? -1) == b then {
      good = good + 1
    }
    b = b + 1
  }
  assert_eq(good, 256)
}

test "sort_by_blob orders entries by byte content" {
  // three entries "cherry","apple","banana" in a blob; sorted idx = a,b,c
  let blob = bytes.from_list(string.to_bytes("cherryapplebanana"))
  let off = [0, 6, 11, 17]
  let sorted = sort_by_blob([0, 1, 2], blob, off)
  assert_eq(sorted, [1, 2, 0]) // apple(1), banana(2), cherry(0)
}

test "cmp_target_range matches, prefixes, and orders" {
  let blob = bytes.from_list(string.to_bytes("banana"))
  assert_eq(cmp_target_range(string.to_bytes("banana"), blob, 0, 6), 0)
  assert_eq(cmp_target_range(string.to_bytes("ban"), blob, 0, 6), -1)   // shorter
  assert_eq(cmp_target_range(string.to_bytes("apple"), blob, 0, 6), -1) // a < b
  assert_eq(cmp_target_range(string.to_bytes("cherry"), blob, 0, 6), 1) // c > b
}

test "pretokenize splits words with leading spaces" {
  let parts = pretokenize("The capital of France is")
  assert_eq(list.len(parts), 5)
  assert_eq(list.get(parts, 0) ?? "", "The")
  assert_eq(list.get(parts, 1) ?? "", " capital")
  assert_eq(list.get(parts, 4) ?? "", " is")
}

test "pretokenize: digit chunks, contractions, punct" {
  let parts = pretokenize("12345 it's here!")
  // 123 | 45 | " it" | 's | " here" | !
  assert_eq(list.len(parts), 6)
  assert_eq(list.get(parts, 0) ?? "", "123")
  assert_eq(list.get(parts, 1) ?? "", "45")
  assert_eq(list.get(parts, 2) ?? "", " it")
  assert_eq(list.get(parts, 3) ?? "", "'s")
  assert_eq(list.get(parts, 4) ?? "", " here")
  assert_eq(list.get(parts, 5) ?? "", "!")
}

test "pretokenize: newlines bind preceding spaces" {
  let parts = pretokenize("a \n\nb")
  // "a" | " \n\n" | "b"
  assert_eq(list.len(parts), 3)
  assert_eq(list.get(parts, 1) ?? "", " \n\n")
}

test "pretokenize: multi-space leaves one for the next word" {
  let parts = pretokenize("a   b")
  // "a" | "  " | " b"
  assert_eq(list.len(parts), 3)
  assert_eq(list.get(parts, 1) ?? "", "  ")
  assert_eq(list.get(parts, 2) ?? "", " b")
}
